# Postgres
POSTGRES_USER=user
POSTGRES_PASSWORD=replace_with_your_local_password
POSTGRES_DB=traindb
DB_HOST=localhost
DB_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=train-doors

# Local dashboard webhook used by the consumer when anomalies are detected
DASHBOARD_ALERT_WEBHOOK=http://localhost:8501/alert_webhook

# Local JSON reports written by Prefect flows
REPORTS_DIR=reports

# Keep local Prefect state inside the project folder
PREFECT_HOME=.prefect
